<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.glycin.cool-cursor</id>
    <name>Smooth Caret Trail</name>
    <vendor>glycin</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <editorFactoryListener implementation="com.glycin.coolcursor.SmoothDashEditorListener"/>
        <applicationService serviceImplementation="com.glycin.coolcursor.CoolCursorSettings"/>
        <applicationConfigurable
                parentId="editor"
                id="com.glycin.coolcursor.settings"
                displayName="Smooth Caret Trail"
                instance="com.glycin.coolcursor.CoolCursorConfigurable"/>
    </extensions>
</idea-plugin>
